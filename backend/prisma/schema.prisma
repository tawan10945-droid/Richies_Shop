generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String
  created_at    DateTime @default(now())
}

model Order {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  account_name    String
  customer_name   String
  set_name        String
  product_name    String
  quantity        Int
  cost            Float
  selling_price   Float
  revenue         Float
  profit          Float
  tracking_number String?
  order_number    String?
  platform        String
  created_at      DateTime @default(now())
}
